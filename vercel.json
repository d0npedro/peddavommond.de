{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/sound", "destination": "/soundcloud", "permanent": false },
    { "source": "/code", "destination": "https://github.com/d0npedro", "permanent": false },
    { "source": "/slotmachine", "destination": "https://slotmachine-gold.vercel.app", "permanent": false },
    { "source": "/slotmachine/:path*", "destination": "https://slotmachine-gold.vercel.app/:path*", "permanent": false }
  ],
  "rewrites": [
    { "source": "/soundcloud", "destination": "/soundcloud.html" },
    { "source": "/twitch", "destination": "/twitch.html" },
    { "source": "/spotify", "destination": "/spotify.html" },
    { "source": "/youtube", "destination": "/youtube.html" },
    { "source": "/facebook", "destination": "/facebook.html" },
    { "source": "/linkedin", "destination": "/linkedin.html" },
    { "source": "/story", "destination": "/story.html" }
  ]
}
